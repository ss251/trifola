{
  "name": "trifola",
  "version": "0.2.4",
  "description": "Finding generator for your Claude Code corpus — dead skills, prompt tax, and re-sent context, priced at API-equivalent rates. Reads ~/.claude locally; uploads nothing.",
  "type": "module",
  "bin": {
    "trifola": "dist/trifola.js"
  },
  "main": "dist/trifola.js",
  "files": [
    "dist/*.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p . && chmod +x dist/trifola.js",
    "test": "tsc -p . && node --test dist/__tests__/*.test.js",
    "start": "node dist/trifola.js",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm test"
  },
  "license": "MIT",
  "author": "ss251",
  "homepage": "https://github.com/ss251/trifola",
  "bugs": {
    "url": "https://github.com/ss251/trifola/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ss251/trifola.git",
    "directory": "cli"
  },
  "keywords": [
    "claude-code",
    "cli",
    "audit",
    "cost",
    "skills",
    "prompt-tax"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^7.0.2"
  }
}
