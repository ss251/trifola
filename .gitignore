# Swift / SwiftPM
.build/
.swiftpm/
Package.resolved
*.xcodeproj/
DerivedData/

# Build output
dist/
*.app/
# …except the CLI's compiled output: it is committed so the README's
# "runs straight from the clone, nothing to install" command is TRUE on a
# clean clone (zero runtime deps; only the test build stays untracked).
!cli/dist/
cli/dist/__tests__/

# macOS
.DS_Store

# Local, private fixtures — real ~/.claude data must NEVER be committed.
# Only synthetic fixtures (Tests/Fixtures/) are tracked.
/fixtures-local/
*.local.jsonl

# Editor / tooling
.vscode/
.idea/
.roast-*
REPORT-*.md

# Regenerable render output (docs/screenshots holds the published set)
screenshots-new/

# Node / npm (cli/) — dist/ above already covers cli/dist/ (unanchored match).
node_modules/
/renders/
/memory/
